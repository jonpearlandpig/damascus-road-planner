{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://damascus-road-planner.local/gear-pack.schema.json",
  "title": "TELAadvance Gear Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["department", "schema", "source_policy", "items"],
  "properties": {
    "department": {
      "type": "string",
      "enum": ["audio", "cameras", "decking", "lighting", "rigging", "sfx", "video"]
    },
    "schema": {
      "const": "_SCHEMA.md"
    },
    "source_policy": {
      "const": "T.I. only — no reference names"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "item", "qty", "status", "weight_lbs", "power", "source", "notes"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(AU|CM|DK|FX|LX|RG|VD)-[0-9]{4}$"
          },
          "item": {
            "type": "string",
            "minLength": 1
          },
          "qty": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "type": "string",
            "enum": ["OWNED", "CANDIDATE", "RENTAL-TBD"]
          },
          "weight_lbs": {
            "oneOf": [
              { "type": "number", "minimum": 0 },
              { "const": "TBD" }
            ]
          },
          "power": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "const": "T.I."
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
